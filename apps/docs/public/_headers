# HTML pages — always revalidate and prevent edge HTML mutation.
# Cloudflare Web Analytics automatic setup injects beacon.min.js unless
# Cache-Control includes no-transform.
/
  Cache-Control: public, max-age=0, must-revalidate, no-transform

/docs
  Cache-Control: public, max-age=0, must-revalidate, no-transform

/docs/*
  Cache-Control: public, max-age=0, must-revalidate, no-transform

/components
  Cache-Control: public, max-age=0, must-revalidate, no-transform

/components/*
  Cache-Control: public, max-age=0, must-revalidate, no-transform

/showcase/portfolio
  Cache-Control: public, max-age=0, must-revalidate, no-transform

/showcase/portfolio/*
  Cache-Control: public, max-age=0, must-revalidate, no-transform

# Crawlers should re-check the canonical robots policy at the edge.
/robots.txt
  Cache-Control: public, max-age=0, must-revalidate, no-transform

# Hashed JS/CSS bundles — content-addressed, safe to cache 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Videos
/angular-mascot.webm
  Cache-Control: public, max-age=86400

/angular-mascot.mp4
  Cache-Control: public, max-age=86400

