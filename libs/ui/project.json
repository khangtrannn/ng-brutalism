{
  "name": "ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ui/src",
  "prefix": "nb",
  "projectType": "library",
  "release": {
    "version": {
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk",
      "preserveLocalDependencyProtocols": false,
      "manifestRootsToUpdate": ["dist/{projectRoot}"]
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/ui"],
      "options": {
        "commands": [
          "pnpm nx run schematics:build",
          "pnpm nx run ui:ng-package",
          "node -e \"require('node:fs').cpSync('dist/libs/schematics/src', 'dist/ui/schematics', { recursive: true })\"",
          "node -e \"require('node:fs').writeFileSync('dist/ui/schematics/package.json', JSON.stringify({ type: 'commonjs' }, null, 2) + '\\n')\"",
          "node -e \"require('node:fs').copyFileSync('LICENSE', 'dist/ui/LICENSE')\"",
          "node -e \"require('node:fs').copyFileSync('CHANGELOG.md', 'dist/ui/CHANGELOG.md')\""
        ],
        "parallel": false
      },
      "configurations": {
        "production": {},
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "ng-package": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/ui"],
      "options": {
        "project": "libs/ui/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/ui/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/ui/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "libs/ui/vitest.config.mts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/ui/**/*.ts", "libs/ui/**/*.html"]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  }
}
